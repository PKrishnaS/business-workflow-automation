# ============================================================
# .env.example — Template for your secrets file
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to ".env"  (no .example)
#   2. Fill in YOUR real values below
#   3. NEVER upload the real .env file to GitHub
#      (it's already in .gitignore, so you're protected)
# ============================================================

# ── Email credentials ────────────────────────────────────────
# For Gmail: use an App Password, not your real Gmail password.
# How to get an App Password:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search for "App passwords"
#   4. Create one for "Mail" → copy the 16-character code here
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# SMTP settings (these defaults work for Gmail — change for Outlook etc.)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Branding ─────────────────────────────────────────────────
COMPANY_NAME=Your Company Name
REPORT_AUTHOR=Your Name

# ── Scheduler ────────────────────────────────────────────────
# What time to run the daily auto-report (24-hour format HH:MM)
SCHEDULER_TIME=08:00

# ── Logging ──────────────────────────────────────────────────
# Options: DEBUG (very detailed), INFO (normal), WARNING, ERROR
LOG_LEVEL=INFO
